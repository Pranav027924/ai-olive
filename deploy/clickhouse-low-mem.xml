<!-- Modest ClickHouse memory caps. Only well-known, always-valid top-level
     server settings live here so the server never refuses to start over an
     unknown config key. Mounted at /etc/clickhouse-server/config.d/low-mem.xml. -->
<clickhouse>
    <!-- Cap server memory at a fraction of RAM (e.g. ~3.2 GB on a 4 GB box). -->
    <max_server_memory_usage_to_ram_ratio>0.8</max_server_memory_usage_to_ram_ratio>
    <!-- Shrink the mark cache (defaults to 5 GB). -->
    <mark_cache_size>536870912</mark_cache_size>   <!-- 512 MB -->
</clickhouse>
