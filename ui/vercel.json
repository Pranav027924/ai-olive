{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/chat/:path*",
      "destination": "https://REPLACE-WITH-CHAT-SERVICE.up.railway.app/:path*"
    },
    {
      "source": "/api/dashboard/:path*",
      "destination": "https://REPLACE-WITH-DASHBOARD-SERVICE.up.railway.app/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
