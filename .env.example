# Copy to `.env` and edit. `.env` is gitignored. Never commit real secrets.
# Container hosts use the compose service name (e.g. POSTGRES_HOST=postgres)
# when accessed from inside another container. Host tools use 127.0.0.1.

# ---- Postgres ----
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=olive
POSTGRES_PASSWORD=olive_dev_pw
POSTGRES_DB=olive

# ---- Redis ----
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ---- MinIO (S3-compatible object storage) ----
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ROOT_USER=olive
MINIO_ROOT_PASSWORD=olive_dev_pw_minio
MINIO_BUCKET=olive-media

# ---- ClickHouse (Phase 7.4, enable via `make up-analytics`) ----
CLICKHOUSE_HOST=127.0.0.1
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9009
CLICKHOUSE_USER=olive
CLICKHOUSE_PASSWORD=olive_dev_pw_ch
CLICKHOUSE_DB=olive

# ---- LLM providers (set the ones you actually use) ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# ---- Auth (PRD §9.4) ----
# Dev/local/UI keep DISABLE_AUTH=true (chat-service falls back to the dev
# user-id). Production sets DISABLE_AUTH=false and a real JWT_SECRET
# (HS256; must be at least 32 bytes). JWT_AUDIENCE / JWT_ISSUER are
# optional and only enforced when set.
DISABLE_AUTH=true
JWT_SECRET=local-dev-jwt-secret-change-me-min-32-bytes
JWT_ALGORITHM=HS256
JWT_AUDIENCE=
JWT_ISSUER=

# ---- Inter-service (PRD §9.5) ----
# INGESTION_API_KEYS is a comma-separated allow-list so keys can be
# rotated with zero downtime: add the new key, roll clients, drop the
# old key. INGESTION_API_KEY (singular) stays supported as a fallback.
INGESTION_API_KEY=local-dev-ingestion-key
INGESTION_API_KEYS=local-dev-ingestion-key
